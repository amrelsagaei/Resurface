{
  "name": "resurface",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint ./packages/**/src",
    "lint:fix": "eslint ./packages/**/src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test": "vitest run --passWithNoTests",
    "build:shared": "pnpm --filter @caido-community/resurface run build",
    "build": "pnpm build:shared && caido-dev build",
    "watch": "caido-dev watch",
    "verify": "pnpm build:shared && pnpm typecheck && pnpm lint && pnpm format:check && pnpm knip && pnpm test"
  },
  "devDependencies": {
    "@caido-community/dev": "0.1.6",
    "@caido/eslint-config": "0.5.0",
    "@caido/tailwindcss": "0.0.1",
    "@vitejs/plugin-vue": "5.2.1",
    "eslint": "9.29.0",
    "knip": "5.70.2",
    "postcss-prefixwrap": "1.51.0",
    "prettier": "3.4.2",
    "tailwindcss": "3.4.13",
    "tailwindcss-primeui": "0.3.4",
    "typescript": "5.5.4",
    "vitest": "4.1.2"
  },
  "pnpm": {
    "overrides": {
      "@caido/sdk-shared": "0.2.2"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
